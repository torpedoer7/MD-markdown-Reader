{
  "name": "md-reader",
  "version": "2.0.0",
  "description": "跨平台 Markdown 阅读器/编辑器",
  "main": "main.js",
  "scripts": {
    "bundle": "esbuild renderer/renderer.js --bundle --outfile=renderer/dist/bundle.js --format=iife --global-name=App",
    "start": "npm run bundle && electron .",
    "build:mac": "npm run bundle && electron-builder --mac",
    "build:win": "npm run bundle && electron-builder --win",
    "build": "npm run bundle && electron-builder --mac --win"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0"
  }
}
